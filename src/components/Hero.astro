---
const githubUrl = "https://github.com/SachinVenugopalan30/sous-clip";
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-content">
      <h1>Rescue recipes<br />from the feed.</h1>
      <p class="hero-sub">
        Sous Clip watches cooking videos so you don't have to. Paste a link,
        get a clean, structured recipe - stored locally, forever yours.
      </p>
      <div class="hero-actions">
        <a href="#quickstart" class="btn-primary">
          Get Started
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href={githubUrl} target="_blank" rel="noopener" class="btn-secondary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>
      <div class="trust-badges">
        <span class="badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Self-hosted
        </span>
        <span class="badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Your API keys
        </span>
        <span class="badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Open source
        </span>
      </div>
    </div>

    <div class="hero-visual">
      <div class="pipeline-card" data-reveal style="--reveal-i: 1">
        <div class="pipeline-header">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="pipeline-title">sous-clip pipeline</span>
        </div>
        <div class="pipeline-steps">
          <div class="step" style="--i: 0">
            <div class="step-icon download">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </div>
            <span class="step-label">Download</span>
            <span class="step-detail">yt-dlp</span>
          </div>
          <div class="step-arrow" style="--i: 0.5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
          <div class="step" style="--i: 1">
            <div class="step-icon transcribe">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            </div>
            <span class="step-label">Transcribe</span>
            <span class="step-detail">Whisper</span>
          </div>
          <div class="step-arrow" style="--i: 1.5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
          <div class="step" style="--i: 2">
            <div class="step-icon extract">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            <span class="step-label">Extract</span>
            <span class="step-detail">LLM</span>
          </div>
          <div class="step-arrow" style="--i: 2.5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
          <div class="step done" style="--i: 3">
            <div class="step-icon saved">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="step-label">Saved</span>
            <span class="step-detail">SQLite</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: calc(var(--section-pad) + 60px) 0 var(--section-pad);
    position: relative;
    overflow: hidden;
  }

  /* Subtle radial glow behind hero */
  .hero::before {
    content: "";
    position: absolute;
    top: -20%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 3.5rem;
    line-height: 1.1;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .hero-sub {
    margin-top: 20px;
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 460px;
    line-height: 1.7;
  }

  .hero-actions {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: white;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 12px 28px;
    border-radius: 100px;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--accent-glow);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 12px 28px;
    border-radius: 100px;
    border: 1.5px solid var(--border);
    transition: border-color 0.2s, transform 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--text-muted);
    transform: translateY(-2px);
  }

  .trust-badges {
    margin-top: 32px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .badge svg {
    opacity: 0.6;
  }

  /* Pipeline Card */
  .hero-visual {
    position: relative;
  }

  .pipeline-card {
    background: var(--dark-bg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.15),
      0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .pipeline-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--dark-surface);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }

  .pipeline-title {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgba(245, 240, 232, 0.5);
  }

  .pipeline-steps {
    padding: 32px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: stepIn 0.5s ease forwards;
    animation-delay: calc(var(--i) * 0.6s + 0.5s);
  }

  .step-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    background: var(--dark-surface);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: box-shadow 0.4s;
  }

  .step.done .step-icon {
    background: rgba(58, 154, 92, 0.15);
    border-color: rgba(58, 154, 92, 0.3);
    color: var(--green);
    animation: greenGlow 2s ease-in-out infinite;
    animation-delay: 3s;
  }

  .step-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--dark-text);
  }

  .step-detail {
    font-size: 0.65rem;
    color: rgba(245, 240, 232, 0.35);
    font-family: var(--font-mono);
  }

  .step-arrow {
    color: rgba(245, 240, 232, 0.2);
    opacity: 0;
    animation: stepIn 0.3s ease forwards;
    animation-delay: calc(var(--i) * 0.6s + 0.5s);
  }

  @keyframes stepIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes greenGlow {
    0%, 100% {
      box-shadow: 0 0 0 rgba(58, 154, 92, 0);
    }
    50% {
      box-shadow: 0 0 20px var(--green-glow);
    }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    h1 {
      font-size: 2.5rem;
    }

    .hero-sub {
      font-size: 1.05rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: calc(var(--section-pad) + 40px) 0 64px;
    }

    h1 {
      font-size: 2.1rem;
    }

    .pipeline-steps {
      flex-direction: column;
      gap: 4px;
    }

    .step-arrow {
      transform: rotate(90deg);
    }
  }
</style>
