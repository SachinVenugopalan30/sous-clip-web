---
const features = [
  {
    icon: "video",
    title: "Multi-platform support",
    description: "YouTube, Instagram, TikTok - if yt-dlp can download it, Sous Clip can extract from it.",
  },
  {
    icon: "mic",
    title: "Whisper transcription",
    description: "OpenAI's Whisper turns spoken instructions into accurate text, even with background music.",
  },
  {
    icon: "key",
    title: "Your own API keys",
    description: "Bring your own OpenAI, Anthropic, or Ollama setup. No middleman, no markup, no data harvesting.",
  },
  {
    icon: "share",
    title: "Export & share",
    description: "Copy recipes as Markdown or share a direct link. Clean formatting, every time.",
  },
  {
    icon: "bookmark",
    title: "Recipe library",
    description: "Browse, search, and filter your collection. Every recipe saved locally in SQLite.",
  },
  {
    icon: "server",
    title: "Docker-ready",
    description: "One command to deploy. Runs on a Raspberry Pi, a NAS, or any machine with Docker.",
  },
];
---

<section class="features">
  <div class="container">
    <h2>Everything you need,<br />nothing you don't.</h2>
    <div class="features-grid">
      {features.map((feature, i) => (
        <div class="feature-card" data-reveal style={`--reveal-i: ${i}`}>
          <div class="feature-icon">
            {feature.icon === "video" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
            )}
            {feature.icon === "mic" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            )}
            {feature.icon === "key" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
            )}
            {feature.icon === "share" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            )}
            {feature.icon === "bookmark" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/><line x1="15" y1="8" x2="9" y2="8"/><line x1="12" y1="5" x2="12" y2="11"/></svg>
            )}
            {feature.icon === "server" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
            )}
          </div>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--section-pad) 0;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 2.25rem;
    text-align: center;
    margin-bottom: 56px;
    letter-spacing: -0.01em;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .feature-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 28px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--cream);
    color: var(--accent);
    margin-bottom: 16px;
    border: 1px solid var(--border);
  }

  h3 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 6px;
  }

  p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
