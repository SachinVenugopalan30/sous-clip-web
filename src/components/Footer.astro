---
const githubUrl = "https://github.com/SachinVenugopalan30/sous-clip";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z" />
        <line x1="6" y1="17" x2="18" y2="17" />
      </svg>
      <span class="wordmark">Sous Clip</span>
    </div>
    <p class="tagline"><em>Your recipes. Your kitchen. Your rules.</em></p>
    <nav class="footer-links">
      <a href={githubUrl} target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
      <span class="sep">/</span>
      <a href={`${githubUrl}#readme`} target="_blank" rel="noopener">Docs</a>
    </nav>
    <p class="sign-off">
      Made with care for people who cook and tinker.<br />
      &copy; {year} Sous Clip
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: 64px 0 48px;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    text-align: center;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    margin-bottom: 8px;
  }

  .footer-brand svg {
    color: var(--accent);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 1.25rem;
  }

  .tagline {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .footer-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .sep {
    color: var(--border);
    font-size: 0.8rem;
  }

  .sign-off {
    font-size: 0.8rem;
    color: var(--text-muted);
    opacity: 0.7;
    line-height: 1.6;
  }
</style>
